{
  "name": "letagentpay",
  "version": "0.2.2",
  "description": "TypeScript SDK for LetAgentPay — AI agent spending policy middleware for fiat and x402 crypto-micropayments",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "spending",
    "policy",
    "budget",
    "llm",
    "openclaw",
    "letagentpay"
  ],
  "author": "LetAgentPay <hello@letagentpay.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LetAgentPay/letagentpay-js"
  },
  "homepage": "https://letagentpay.com",
  "bugs": {
    "url": "https://github.com/LetAgentPay/letagentpay-js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
